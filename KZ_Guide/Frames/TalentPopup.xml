<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!-- Talent Toast Notification -->
    <Frame name="GLV_TalentToast" parent="UIParent" toplevel="true" movable="true" hidden="true" frameStrata="DIALOG" enableMouse="true">
        <Size>
            <AbsDimension x="300" y="40"/>
        </Size>
        <Anchors>
            <Anchor point="TOP" x="0" y="-100"/>
        </Anchors>

        <Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
            <EdgeSize>
                <AbsValue val="14"/>
            </EdgeSize>
            <TileSize>
                <AbsValue val="8"/>
            </TileSize>
            <BackgroundInsets>
                <AbsInset left="3" right="3" top="3" bottom="3"/>
            </BackgroundInsets>
        </Backdrop>

        <Scripts>
            <OnLoad>
                this:SetBackdropColor(0, 0, 0, 0.85);
                GLV_TalentToast_RestorePosition();
            </OnLoad>
            <OnMouseUp>
                if GLV and GLV.TalentTracker then
                    GLV.TalentTracker:DismissToast();
                end
            </OnMouseUp>
            <OnDragStart>
                if this.isMoving then
                    this:StartMoving();
                end
            </OnDragStart>
            <OnDragStop>
                this:StopMovingOrSizing();
                GLV_TalentToast_SavePosition();
            </OnDragStop>
        </Scripts>

        <Layers>
            <Layer level="ARTWORK">
                <!-- Talent Icon -->
                <Texture name="$parentIcon">
                    <Size>
                        <AbsDimension x="24" y="24"/>
                    </Size>
                    <Anchors>
                        <Anchor point="CENTER" x="0" y="0"/>
                    </Anchors>
                </Texture>

                <!-- Text -->
                <FontString name="$parentText" inherits="GameFontNormal">
                    <Anchors>
                        <Anchor point="CENTER" x="0" y="0"/>
                    </Anchors>
                </FontString>

                <!-- Respec Message Text (hidden by default) -->
                <FontString name="$parentMessage" inherits="GameFontNormalSmall" hidden="true">
                    <Anchors>
                        <Anchor point="CENTER" x="0" y="0"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Frame>

    <!-- Independent Talent Highlight Frame -->
    <Frame name="GLV_TalentHighlight" parent="UIParent" hidden="true" frameStrata="FULLSCREEN_DIALOG" enableMouse="false">
        <Size>
            <AbsDimension x="50" y="50"/>
        </Size>
        <Layers>
            <Layer level="OVERLAY">
                <Texture name="$parentGlow" file="Interface\Buttons\UI-ActionButton-Border" alphaMode="ADD">
                    <Size>
                        <AbsDimension x="70" y="70"/>
                    </Size>
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                    <Color r="0" g="1" b="0"/>
                </Texture>
            </Layer>
        </Layers>
    </Frame>

</Ui>
